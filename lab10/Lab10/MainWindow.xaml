<Window x:Class="SimulationLabs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Лабораторная работа 10: СМО M/M/n с усложнениями"
        Width="1050" Height="750"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ParamLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="ParamBox" TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="70"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Система массового обслуживания M/M/n с усложнениями"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Панель параметров -->
        <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,10" Background="#F9F9F9">
            <StackPanel>
                <TextBlock Text="Параметры модели" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <WrapPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="λ:"/>
                    <TextBox x:Name="txtLambda" Style="{StaticResource ParamBox}" Text="3"/>
                    <TextBlock Style="{StaticResource ParamLabel}" Text="μ:"/>
                    <TextBox x:Name="txtMu" Style="{StaticResource ParamBox}" Text="2"/>
                    <TextBlock Style="{StaticResource ParamLabel}" Text="n (серверы):"/>
                    <TextBox x:Name="txtN" Style="{StaticResource ParamBox}" Text="2"/>
                    <TextBlock Style="{StaticResource ParamLabel}" Text="Очередь:"/>
                    <TextBox x:Name="txtQueueSize" Style="{StaticResource ParamBox}" Text="5"/>
                    <TextBlock Style="{StaticResource ParamLabel}" Text="Терпение:"/>
                    <TextBox x:Name="txtPatience" Style="{StaticResource ParamBox}" Text="10"/>
                    <TextBlock Style="{StaticResource ParamLabel}" Text="T (время):"/>
                    <TextBox x:Name="txtT" Style="{StaticResource ParamBox}" Text="500"/>
                    <Button x:Name="btnRun" Content="▶ Запустить" Margin="15,0,0,0"
                            Padding="20,8" FontSize="13" FontWeight="Bold"
                            Background="#90EE90" BorderBrush="#4CAF50" BorderThickness="1"
                            Click="BtnRun_Click"/>
                    <Button x:Name="btnExport" Content="💾 Экспорт" Margin="10,0,0,0"
                            Padding="15,8" FontSize="13" FontWeight="Bold"
                            Background="#ADD8E6" BorderBrush="#4682B4" BorderThickness="1"
                            Click="BtnExport_Click" IsEnabled="False"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Графики -->
        <TabControl Grid.Row="2">
            <TabItem Header="Очередь и серверы">
                <lvc:CartesianChart x:Name="chartQueue" DisableAnimations="True" LegendLocation="Right" Zoom="Xy">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Время"/>
                    </lvc:CartesianChart.AxisX>
                </lvc:CartesianChart>
            </TabItem>
            <TabItem Header="Итоги">
                <lvc:CartesianChart x:Name="chartResults" DisableAnimations="True" LegendLocation="Right"/>
            </TabItem>
            <TabItem Header="Лог событий">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="txtLog" FontFamily="Consolas" FontSize="11" Text="Запустите симуляцию" TextWrapping="Wrap"/>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Статус -->
        <TextBlock x:Name="lblStatus" Grid.Row="3" Text="Готово к запуску" FontWeight="SemiBold" Margin="0,5,0,0"/>
    </Grid>
</Window>

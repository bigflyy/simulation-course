<Window x:Class="SimulationLabs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Лабораторная работа 8: Пуассоновский поток"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ParamLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="ParamBox" TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="80"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Пуассоновский поток запросов на сервер"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Панель параметров -->
        <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,10" Background="#F9F9F9">
            <StackPanel>
                
                <TextBlock Text="Параметры модели" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="λ (интенсивность):"/>
                    <TextBox x:Name="txtLambda" Style="{StaticResource ParamBox}" Text="5"/>
                    <TextBlock Style="{StaticResource ParamLabel}" Text="T (интервал, дни):"/>
                    <TextBox x:Name="txtT" Style="{StaticResource ParamBox}" Text="30"/>
                    <TextBlock Style="{StaticResource ParamLabel}" Text="N (экспериментов):"/>
                    <TextBox x:Name="txtN" Style="{StaticResource ParamBox}" Text="1000"/>
                    <Button x:Name="btnRun" Content="▶ Запустить" Margin="20,0,0,0"
                            Padding="20,8" FontSize="13" FontWeight="Bold"
                            Background="#90EE90" BorderBrush="#4CAF50" BorderThickness="1"
                            Click="BtnRun_Click"/>
                </WrapPanel>
                <!-- СТРОКА 2: Демонстрация (НОВОЕ) -->
                <!-- Отступ сверху, тонкая линия-разделитель -->
                <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,10,0,10"/>

                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Демонстрация (один запуск):" 
                               FontWeight="SemiBold" Foreground="#555" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <TextBlock Style="{StaticResource ParamLabel}" Text="T:"/>
                    <TextBox x:Name="txtDemoT" Style="{StaticResource ParamBox}" Text="10"/>
                    <Button Content="✓ Проверить" Margin="5,0,0,0" Padding="10,5" 
                            Click="BtnDemoRun_Click"/>
                    <TextBlock x:Name="lblDemoResult" Text="—" 
                               FontWeight="Bold" Foreground="DarkBlue" 
                               VerticalAlignment="Center" Margin="15,0,0,0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- График распределения -->
        <GroupBox Grid.Row="2" Header="Распределение числа запросов" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <!-- LiveCharts график -->
                <lvc:CartesianChart x:Name="chartDist" Grid.Column="0" LegendLocation="Right" DisableAnimations="True">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Число запросов (k)"/>
                    </lvc:CartesianChart.AxisX>
                </lvc:CartesianChart>

                <!-- Панель результатов -->
                <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1,0,0,0" Margin="10,0,0,0" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Результаты" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                        <TextBlock Text="Эмпирические:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                        <TextBlock x:Name="lblEmpMean" Text="Среднее: —"/>
                        <TextBlock x:Name="lblEmpVar" Text="Дисперсия: —"/>

                        <TextBlock Text="Теоретические (λ·T):" FontWeight="SemiBold" Margin="0,10,0,0"/>
                        <TextBlock x:Name="lblTheoMean" Text="Среднее: —"/>
                        <TextBlock x:Name="lblTheoVar" Text="Дисперсия: —"/>

                        <TextBlock Text="Заключение:" FontWeight="SemiBold" Margin="0,15,0,5"/>
                        <TextBlock x:Name="lblConclusion" Text="Запустите симуляцию" TextWrapping="Wrap"/>

                        <!-- Таблица частот -->
                        <TextBlock Text="Топ частот:" FontWeight="SemiBold" Margin="0,15,0,5"/>
                        <ListView x:Name="lstFrequencies" BorderThickness="0" Height="180">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="k" Width="40" DisplayMemberBinding="{Binding K}"/>
                                    <GridViewColumn Header="Эмпир." Width="70" DisplayMemberBinding="{Binding Empirical}"/>
                                    <GridViewColumn Header="Теор." Width="70" DisplayMemberBinding="{Binding Theoretical}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>
        </GroupBox>

        <!-- Статус -->
        <TextBlock x:Name="lblStatus" Grid.Row="3" Text="Готово к запуску" FontWeight="SemiBold" Margin="0,5,0,0"/>
    </Grid>
</Window>
